# ============================================
# Go Adventure - Dokploy Environment Variables
# ============================================
# Copy this file and fill in your values in Dokploy's Environment Variables section

# ===================
# REQUIRED VARIABLES
# ===================

# Database (PostgreSQL)
DB_DATABASE=go_adventure
DB_USERNAME=go_adventure
DB_PASSWORD=<generate-strong-password>

# Redis
REDIS_PASSWORD=<generate-strong-password>

# Laravel App Key
# Generate with: php -r "echo 'base64:' . base64_encode(random_bytes(32)) . PHP_EOL;"
APP_KEY=base64:XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# URLs (replace with your actual domains)
APP_URL=https://api.yourdomain.com
WEB_URL=https://yourdomain.com

# CORS/Auth - domains that can authenticate (comma-separated)
SANCTUM_DOMAINS=yourdomain.com,api.yourdomain.com

# ===================
# OPTIONAL VARIABLES
# ===================

# Default locale (fr or en)
DEFAULT_LOCALE=fr

# Mail Configuration (SMTP)
# Leave empty to disable email sending (uses log driver)
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@yourdomain.com

# ===================
# DOKPLOY SETUP NOTES
# ===================
#
# 1. In Dokploy Dashboard:
#    - Create Project -> "Go Adventure"
#    - Add Service -> "Docker Compose"
#    - Source: Your GitHub repository
#    - Compose File Path: docker-compose.dokploy.yml
#
# 2. Add all environment variables above in Dokploy's Environment Variables section
#
# 3. Configure Domains in Dokploy:
#    - api service -> api.yourdomain.com (port 80)
#    - web service -> yourdomain.com (port 3000)
#    - Enable SSL (Let's Encrypt) for both
#
# 4. Deploy!
#
# ===================
# GENERATE PASSWORDS
# ===================
# Use strong passwords. Generate with:
#   openssl rand -base64 32
#
# Generate APP_KEY:
#   php -r "echo 'base64:' . base64_encode(random_bytes(32)) . PHP_EOL;"
