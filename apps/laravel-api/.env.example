APP_NAME="Evasion Djerba"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_VERSION=0.1.0

# Frontend URL (for CORS and email links)
# Production: https://www.evasiondjerba.com
FRONTEND_URL=http://localhost:3000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database (PostgreSQL)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=evasion_djerba
DB_USERNAME=evasion_djerba
DB_PASSWORD=secret

# Session & Cache
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# For subdomain cookie sharing, set to .evasiondjerba.com in production
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=minio
QUEUE_CONNECTION=redis

CACHE_STORE=redis

# Redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail Configuration
# Development: Use smtp with Mailpit (MAIL_HOST=mailpit, MAIL_PORT=1025)
# Production: Use resend (MAIL_MAILER=resend)
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="bookings@evasiondjerba.com"
MAIL_FROM_NAME="${APP_NAME}"

# Resend API (required when MAIL_MAILER=resend)
# Get your API key from https://resend.com
RESEND_API_KEY=

# MinIO (S3-compatible storage)
AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=minio123
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=evasion-djerba
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

# MeiliSearch
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=masterkey123

# Google Maps
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_CACHE_TTL=2592000

# Horizon
HORIZON_PREFIX=evasion-djerba-horizon

# Sanctum - Stateful domains for cookie-based auth
# Production: staging.evasiondjerba.com,www.evasiondjerba.com,evasiondjerba.com
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,localhost:3001
