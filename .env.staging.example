# Staging Environment Variables
# Copy this file to .env in your staging deployment directory and fill in values
# Each value marked CHANGE_ME must be replaced with a unique, strong value

# ============================================================================
# Docker Compose Project Name (REQUIRED - isolates containers from production)
# ============================================================================
COMPOSE_PROJECT_NAME=goadventure-staging

# ============================================================================
# Laravel API Configuration
# ============================================================================
APP_NAME="Go Adventure Staging"
APP_ENV=staging
APP_KEY=  # Generate with: docker compose -f docker-compose.staging.yml exec api php artisan key:generate --show
APP_DEBUG=true
APP_TIMEZONE=Africa/Tunis
APP_URL=https://staging-app.go-adventure.net
FRONTEND_URL=https://staging.go-adventure.net
APP_LOCALE=fr
APP_FALLBACK_LOCALE=en

# ============================================================================
# Database Configuration (ISOLATED from production)
# ============================================================================
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=go_adventure_staging
DB_USERNAME=go_adventure_staging
DB_PASSWORD=CHANGE_ME_staging_db_password

# ============================================================================
# Redis Configuration (ISOLATED from production)
# ============================================================================
REDIS_HOST=redis
REDIS_PASSWORD=CHANGE_ME_staging_redis_password
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# ============================================================================
# Queue & Cache Configuration
# ============================================================================
QUEUE_CONNECTION=redis
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ============================================================================
# Horizon Configuration
# ============================================================================
HORIZON_PREFIX=go-adventure-staging-horizon
HORIZON_BALANCE=auto
HORIZON_MAX_PROCESSES=5

# ============================================================================
# Mail Configuration (defaults to log - no real emails sent)
# ============================================================================
MAIL_MAILER=log
MAIL_FROM_ADDRESS=staging@go-adventure.net
MAIL_FROM_NAME="Go Adventure Staging"
# Uncomment and fill to send real emails in staging:
# MAIL_MAILER=resend
# RESEND_API_KEY=

# ============================================================================
# File Storage Configuration
# ============================================================================
FILESYSTEM_DISK=local

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_CHANNEL=daily
LOG_LEVEL=debug
LOG_DAYS=7

# ============================================================================
# Next.js Frontend Configuration (baked into image at build time)
# ============================================================================
NEXT_PUBLIC_API_URL=https://staging-app.go-adventure.net/api/v1
NEXT_PUBLIC_APP_URL=https://staging.go-adventure.net
NEXT_PUBLIC_DEFAULT_LOCALE=fr
NODE_ENV=production

# ============================================================================
# Security
# ============================================================================
SANCTUM_STATEFUL_DOMAINS=staging.go-adventure.net,staging-app.go-adventure.net
SESSION_DOMAIN=

# ============================================================================
# Turnstile (disabled by default in staging)
# ============================================================================
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
NEXT_PUBLIC_TURNSTILE_ENABLED=false
