# Djerba Fun - Root Environment
COMPOSE_PROJECT_NAME=djerba-fun

# Database
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=djerba_fun
DB_USERNAME=djerba_fun
DB_PASSWORD=secret

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# MinIO (S3-compatible storage)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123
MINIO_BUCKET=djerba-fun

# MeiliSearch
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_KEY=masterkey123
