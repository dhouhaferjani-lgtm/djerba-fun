# Dev Environment Variables
# Copy this file to .env in your dev deployment directory and fill in values
# Each value marked CHANGE_ME must be replaced with a unique, strong value

# ============================================================================
# Docker Compose Project Name (REQUIRED - isolates containers from production)
# ============================================================================
COMPOSE_PROJECT_NAME=goadventure-dev

# ============================================================================
# Laravel API Configuration
# ============================================================================
APP_NAME="Go Adventure Dev"
APP_ENV=local
APP_KEY=  # Generate with: docker compose -f docker-compose.devenv.yml exec api php artisan key:generate --show
APP_DEBUG=true
APP_TIMEZONE=Africa/Tunis
APP_URL=https://dev-app.go-adventure.net
FRONTEND_URL=https://dev.go-adventure.net
APP_LOCALE=fr
APP_FALLBACK_LOCALE=en

# ============================================================================
# Database Configuration (ISOLATED from production)
# ============================================================================
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=go_adventure_dev
DB_USERNAME=go_adventure_dev
DB_PASSWORD=CHANGE_ME_dev_db_password

# ============================================================================
# Redis Configuration (ISOLATED from production)
# ============================================================================
REDIS_HOST=redis
REDIS_PASSWORD=CHANGE_ME_dev_redis_password
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# ============================================================================
# Queue & Cache Configuration
# ============================================================================
QUEUE_CONNECTION=redis
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ============================================================================
# Mail Configuration (log only - never send real emails from dev)
# ============================================================================
MAIL_MAILER=log
MAIL_FROM_ADDRESS=dev@go-adventure.net
MAIL_FROM_NAME="Go Adventure Dev"

# ============================================================================
# File Storage Configuration
# ============================================================================
FILESYSTEM_DISK=local

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_CHANNEL=daily
LOG_LEVEL=debug
LOG_DAYS=3

# ============================================================================
# Next.js Frontend Configuration (baked into image at build time)
# ============================================================================
NEXT_PUBLIC_API_URL=https://dev-app.go-adventure.net/api/v1
NEXT_PUBLIC_APP_URL=https://dev.go-adventure.net
NEXT_PUBLIC_DEFAULT_LOCALE=fr
NODE_ENV=production

# ============================================================================
# Security
# ============================================================================
SANCTUM_STATEFUL_DOMAINS=dev.go-adventure.net,dev-app.go-adventure.net
SESSION_DOMAIN=

# ============================================================================
# Turnstile (disabled in dev)
# ============================================================================
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
NEXT_PUBLIC_TURNSTILE_ENABLED=false
